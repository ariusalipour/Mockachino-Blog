---
import BrowseControls from "../../components/BrowseControls.astro";
import PagedGrid from "../../components/PagedGrid.astro";
import Layout from "../../layouts/Layout.astro";
import { glossaryTerms } from "../../data/wiki-content";

const params = Astro.url.searchParams;
const initialQ = params.get("q") ?? "";
const listId = "glossary-list";
---

<Layout title="Glossary | MOCKACHINO" description="Glossary of recurring wiki terms." currentPath={Astro.url.pathname}>
  <div class="page-stack">
    <section class="panel taxonomy-hero">
      <p class="section-label">Glossary</p>
      <h1>Shared terms used across the wiki.</h1>
      <p class="taxonomy-copy">
        A small reference index for the phrases, shorthand, and evaluation terms that show up repeatedly across entries.
      </p>
    </section>

    <BrowseControls
      total={glossaryTerms.length}
      listId={listId}
      initialQ={initialQ}
      placeholder="Filter by term or definition"
      resultsLabel="terms visible"
      showKinds={false}
    />

    <div class="section-heading section-heading--compact">
      <div>
        <p class="section-label">Glossary Entries</p>
        <h2>Definitions and shorthand used across the wiki.</h2>
      </div>
    </div>

    <PagedGrid id={listId} className="glossary-grid" perPage={12}>
      {
        glossaryTerms.map((item) => (
          <dl class="panel" data-page-item data-search={`${item.term} ${item.definition}`.toLowerCase()}>
            <dt>{item.term}</dt>
            <dd>{item.definition}</dd>
          </dl>
        ))
      }
    </PagedGrid>
  </div>
</Layout>
