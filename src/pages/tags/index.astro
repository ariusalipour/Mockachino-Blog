---
import BrowseControls from "../../components/BrowseControls.astro";
import PagedGrid from "../../components/PagedGrid.astro";
import Layout from "../../layouts/Layout.astro";
import { getTags } from "../../data/wiki-content";

const tags = getTags();
const params = Astro.url.searchParams;
const initialQ = params.get("q") ?? "";
const listId = "tags-list";
---

<Layout title="Tags | MOCKACHINO" description="Browse the wiki by tag." currentPath={Astro.url.pathname}>
  <div class="page-stack">
    <section class="panel taxonomy-hero">
      <p class="section-label">Tags</p>
      <h1>Cross-topic shortcuts for recurring themes.</h1>
      <p class="taxonomy-copy">
        Tags connect pages that share workflows, hardware, or concepts even when they live in different categories.
      </p>
    </section>

    <BrowseControls
      total={tags.length}
      listId={listId}
      initialQ={initialQ}
      placeholder="Filter tags by name"
      resultsLabel="tags visible"
      showKinds={false}
    />

    <div class="section-heading section-heading--compact">
      <div>
        <p class="section-label">Tag Index</p>
        <h2>Browse recurring themes and shortcuts.</h2>
      </div>
    </div>

    <PagedGrid id={listId} className="tag-grid" perPage={12}>
      {
        tags.map((tag) => (
          <article class="panel tag-card" data-page-item data-search={`${tag.name} ${tag.count}`.toLowerCase()}>
            <h3>#{tag.name}</h3>
            <p>{tag.count} linked entries</p>
            <a href={`/browse/?tag=${encodeURIComponent(tag.name)}`} class="button button--secondary">Browse Tag</a>
          </article>
        ))
      }
    </PagedGrid>
  </div>
</Layout>
