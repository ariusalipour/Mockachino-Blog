---
import BrowseControls from "../../components/BrowseControls.astro";
import EntryList from "../../components/EntryList.astro";
import Layout from "../../layouts/Layout.astro";
import { getEntriesByTag, getTags } from "../../data/wiki-content";

export function getStaticPaths() {
  return getTags().map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const resolvedTag = getTags().find((candidate) => candidate.slug === Astro.params.tag) ?? tag;
const entries = getEntriesByTag(resolvedTag.name);
const params = Astro.url.searchParams;
const initialQ = params.get("q") ?? "";
const listId = `tag-list-${resolvedTag.slug}`;
---

<Layout title={`#${resolvedTag.name} | MOCKACHINO`} description={`Pages tagged ${resolvedTag.name}.`} currentPath={Astro.url.pathname}>
  <div class="page-stack">
    <section class="panel taxonomy-hero">
      <p class="section-label">Tag</p>
      <h1>#{resolvedTag.name}</h1>
      <p class="taxonomy-copy">
        {resolvedTag.count} linked entries share this tag. Use the search below to narrow the list further.
      </p>
      <div class="meta-strip">
        <span class="meta-chip">{resolvedTag.count} entries</span>
      </div>
    </section>

    <BrowseControls
      total={entries.length}
      listId={listId}
      initialQ={initialQ}
      placeholder={`Filter entries tagged ${resolvedTag.name}`}
      resultsLabel="entries visible"
      showKinds={true}
    />

    <section class="panel">
      <div class="section-heading section-heading--compact">
        <div>
          <p class="section-label">Tagged Entries</p>
          <h2>All pages carrying #{resolvedTag.name}.</h2>
        </div>
      </div>
      <EntryList entries={entries} perPage={10} id={listId} />
    </section>
  </div>
</Layout>
