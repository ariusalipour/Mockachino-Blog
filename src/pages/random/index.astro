---
import Layout from "../../layouts/Layout.astro";
import { wikiEntries } from "../../data/wiki-content";
---

<Layout title="Random Page | MOCKACHINO" description="Jump to a random wiki entry." currentPath={Astro.url.pathname}>
  <section class="panel taxonomy-hero">
    <p class="section-label">Random Page</p>
    <h1>Sampling a random entry from the wiki index.</h1>
    <p class="taxonomy-copy">If the redirect does not fire, use one of the fallback links below.</p>
    <div class="tag-cloud">
      {wikiEntries.slice(0, 6).map((entry) => <a href={`/wiki/${entry.slug}/`} class="tag-chip">{entry.title}</a>)}
    </div>
  </section>

  <script is:inline define:vars={{ slugs: wikiEntries.map((entry) => `/wiki/${entry.slug}/`) }}>
    const destination = slugs[Math.floor(Math.random() * slugs.length)];
    window.location.replace(destination);
  </script>
</Layout>
