---
import Layout from "../../layouts/Layout.astro";
import RasterIcon from "../../components/RasterIcon.astro";
import {
  formatCategoryLabel,
  formatTopicLabel,
  getArticleView,
  getEntriesByTopic,
  getEntry,
  getRelatedEntries,
  getTopic,
  wikiEntries,
} from "../../data/wiki";
import { formatDate } from "../../lib/format";

export function getStaticPaths() {
  return wikiEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const articleView = getArticleView(entry);
const relatedEntries = getRelatedEntries(entry, 3);
const topic = getTopic(entry.topic);
const topicEntries = getEntriesByTopic(entry.topic);
const entryIndex = topicEntries.findIndex((candidate) => candidate.slug === entry.slug);
const previousEntry = entryIndex > 0 ? topicEntries[entryIndex - 1] : undefined;
const nextEntry = entryIndex >= 0 && entryIndex < topicEntries.length - 1 ? topicEntries[entryIndex + 1] : undefined;
const articleInfoLabel = `${formatTopicLabel(entry.topic)} / ${formatCategoryLabel(entry.topic, entry.category)}`;
---

<Layout
  title={`${entry.title} | MOCKACHINO`}
  description={entry.summary}
  currentPath={Astro.url.pathname}
  headerPath="/browse/"
  pageClass="page-article"
>
  <div slot="subheader" class="panel article-breadcrumb">
    <a href={`/topics/${entry.topic}/`} class="article-breadcrumb__item">{topic?.name}</a>
    <span class="article-breadcrumb__sep">›</span>
    <a href={`/topics/${entry.topic}/${entry.category}/`} class="article-breadcrumb__item">
      {formatCategoryLabel(entry.topic, entry.category)}
    </a>
    <span class="article-breadcrumb__sep">›</span>
    <span class="article-breadcrumb__item article-breadcrumb__item--current">{entry.title}</span>
  </div>

  <section class="article-layout">
    <article class="panel article-main">
      <header class="article-main__hero">
        <div class="article-main__kicker-row">
          <p class="section-label article-main__kicker">// {formatCategoryLabel(entry.topic, entry.category)}</p>
          <p class="article-main__id">ARTICLE ID: {articleView.articleId}</p>
        </div>
        <h1>{entry.title}</h1>
        <p class="article-main__summary">{entry.summary}</p>

        <div class="article-main__meta">
          <span><RasterIcon name="book" class="article-main__meta-icon article-main__meta-icon--raster" /> {formatDate(entry.createdAt)}</span>
          <span><RasterIcon name="pulse" class="article-main__meta-icon article-main__meta-icon--raster" /> {articleView.readMinutes} MIN READ</span>
          <span><RasterIcon name="user" class="article-main__meta-icon article-main__meta-icon--raster" /> MOCKA</span>
          <span class="article-main__meta-topic">{entry.topic.toUpperCase()}</span>
        </div>
      </header>

      <div class="article-main__visual panel">
        <img src={articleView.heroAsset} alt={`${entry.title} hero visual`} />
      </div>

      <div class="article-sections">
        {
          articleView.sections.map((section) => (
            <section class="article-section" id={section.id}>
              <h2>
                <span>{section.number}</span>
                <span>{section.title}</span>
              </h2>
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

              {section.takeaway && (
                <div class="article-takeaway">
                  <div class="article-takeaway__icon">
                    <RasterIcon name="target" class="article-takeaway__icon-mark article-takeaway__icon-mark--raster" />
                  </div>
                  <div class="article-takeaway__content">
                    <p class="article-takeaway__label">Key Takeaway</p>
                    <p>{section.takeaway}</p>
                  </div>
                </div>
              )}

              {section.comparisonRows && (
                <div class="article-compare">
                  <div class="article-compare__header">
                    <span>Model</span>
                    <span>Best Used For</span>
                    <span>Speed Range</span>
                    <span>Notes</span>
                  </div>
                  {section.comparisonRows.map((row) => (
                    <div class="article-compare__row">
                      <span>{row.model}</span>
                      <span>{row.bestUsedFor}</span>
                      <span>{row.speedRange}</span>
                      <span>{row.notes}</span>
                    </div>
                  ))}
                </div>
              )}

              {section.metricCards && (
                <div class="article-metrics">
                  {section.metricCards.map((metric) => (
                    <article class="article-metric-card">
                      <RasterIcon name={metric.icon} class="article-metric-card__icon article-metric-card__icon--raster" />
                      <h3>{metric.title}</h3>
                      <p>{metric.body}</p>
                    </article>
                  ))}
                </div>
              )}
            </section>
          ))
        }
      </div>

      <footer class="article-pagination">
        <a href={previousEntry ? `/wiki/${previousEntry.slug}/` : "#"} class:list={["article-pagination__link", !previousEntry && "is-disabled"]}>
          <span class="article-pagination__label">Previous Article</span>
          <span class="article-pagination__title">{previousEntry?.title ?? "No earlier article"}</span>
        </a>
        <a href={nextEntry ? `/wiki/${nextEntry.slug}/` : "#"} class:list={["article-pagination__link", !nextEntry && "is-disabled"]}>
          <span class="article-pagination__label">Next Article</span>
          <span class="article-pagination__title">{nextEntry?.title ?? "No next article"}</span>
        </a>
      </footer>
    </article>

    <aside class="article-rail">
      <section class="panel article-rail__panel">
        <p class="panel__kicker">Table Of Contents</p>
        <ol class="article-toc">
          {
            articleView.toc.map((item, index) => (
              <li>
                <a href={`#${articleView.sections[index]?.id}`}>
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <span>{item}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="panel article-rail__panel article-rail__schematic">
        <img src={articleView.schematicAsset} alt={`${entry.title} reference schematic`} />
        <div class="article-rail__schematic-meta">
          <span>{articleView.schematicLabel}</span>
          <span>{articleView.schematicRef}</span>
        </div>
      </section>

      <section class="panel article-rail__panel">
        <p class="panel__kicker">Article Information</p>
        <dl class="article-info">
          <div>
            <dt>Topic</dt>
            <dd>{formatTopicLabel(entry.topic)}</dd>
          </div>
          <div>
            <dt>Category</dt>
            <dd>{formatCategoryLabel(entry.topic, entry.category)}</dd>
          </div>
          <div>
            <dt>Tags</dt>
            <dd class="article-info__tags">
              {entry.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
            </dd>
          </div>
          <div>
            <dt>Difficulty</dt>
            <dd>
              <div class="article-difficulty" aria-label={`Difficulty ${articleView.difficulty} of 7`}>
                {Array.from({ length: 7 }).map((_, index) => <span class:list={[index < articleView.difficulty && "is-active"]}></span>)}
              </div>
            </dd>
          </div>
          <div>
            <dt>Last Updated</dt>
            <dd>{formatDate(entry.updatedAt)}</dd>
          </div>
          <div>
            <dt>Version</dt>
            <dd>{articleView.version}</dd>
          </div>
          <div>
            <dt>Ref</dt>
            <dd>{articleInfoLabel}</dd>
          </div>
        </dl>
      </section>

      <section class="panel article-rail__panel">
        <p class="panel__kicker">Related Articles</p>
        <div class="article-related">
          {
            relatedEntries.map((related) => (
              <a href={`/wiki/${related.slug}/`} class="article-related__item" data-topic={related.topic}>
                <div class="article-related__thumb">
                  <img
                    src={related.topic === "shoots" ? "/brand/topic-shoots-panel.png" : related.topic === "plays" ? "/brand/topic-plays-panel.png" : "/brand/topic-codes-panel.png"}
                    alt=""
                  />
                </div>
                <div class="article-related__body">
                  <span class="article-related__title">{related.title}</span>
                  <span class="article-related__meta">{formatTopicLabel(related.topic)} · {related.kind.toUpperCase()}</span>
                </div>
              </a>
            ))
          }
        </div>
        <a href="/browse/" class="panel-footer-link">View All Resources</a>
      </section>

      <section class="panel article-rail__panel">
        <p class="panel__kicker">Helpful Resources</p>
        <div class="article-resources">
          {
            articleView.resources.map((resource) => (
              <div class="article-resource">
                <RasterIcon name="book" class="article-resource__icon article-resource__icon--raster" />
                <div>
                  <p class="article-resource__title">{resource.title}</p>
                  <p class="article-resource__meta">{resource.meta}</p>
                </div>
                <span class="article-resource__type">{resource.type}</span>
              </div>
            ))
          }
        </div>
        <a href="/browse/" class="panel-footer-link">View All Resources</a>
      </section>
    </aside>
  </section>
</Layout>
