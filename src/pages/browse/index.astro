---
import EntryList from "../../components/EntryList.astro";
import Layout from "../../layouts/Layout.astro";
import { getTags, wikiEntries } from "../../data/wiki";
---

<Layout title="Browse | MOCKACHINO" description="Browse all wiki entries." currentPath={Astro.url.pathname}>
  <div class="page-stack">
    <section class="panel taxonomy-hero">
      <p class="section-label">/// BROWSE ALL</p>
      <h1>All articles, reviews, and guides in one indexed register.</h1>
      <p class="taxonomy-copy">
        Use the live filter below or jump in through tags. Header search feeds into this page so the same route can
        handle direct browsing and targeted lookup.
      </p>
      <div class="meta-strip">
        <span class="meta-chip">{wikiEntries.length} entries</span>
        <span class="meta-chip">{wikiEntries.filter(e => e.kind === "article").length} Articles</span>
        <span class="meta-chip">{wikiEntries.filter(e => e.kind === "guide").length} Guides</span>
        <span class="meta-chip">{wikiEntries.filter(e => e.kind === "review").length} Reviews</span>
      </div>
    </section>

    <section class="panel browse-controls">
      <div class="filter-bar">
        <input id="browse-filter" type="search" placeholder="Filter by title, summary, topic, category, or tag" />
      </div>
      <div class="tag-cloud">
        {
          getTags().map((tag) => (
            <a href={`/browse/?tag=${encodeURIComponent(tag.name)}`} class="tag-chip">
              #{tag.name} / {tag.count}
            </a>
          ))
        }
      </div>
      <p class="results-meta"><span id="results-count">{wikiEntries.length}</span> entries visible</p>
    </section>

    <section class="panel" id="browse-list">
      <div class="section-heading">
        <div>
          <p class="section-label">Entries</p>
          <h2>All pages in the wiki.</h2>
        </div>
      </div>
      <EntryList entries={wikiEntries} />
    </section>
  </div>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const items = [...document.querySelectorAll("#browse-list .entry-list__item")];
    const input = document.querySelector("#browse-filter");
    const counter = document.querySelector("#results-count");
    const q = (params.get("q") ?? params.get("tag") ?? "").toLowerCase();

    if (input) input.value = q;

    const applyFilter = (value) => {
      const needle = value.trim().toLowerCase();
      let visible = 0;

      items.forEach((item) => {
        const haystack = item.dataset.search ?? "";
        const match = !needle || haystack.includes(needle);
        item.style.display = match ? "" : "none";
        if (match) visible += 1;
      });

      if (counter) counter.textContent = String(visible);
    };

    applyFilter(q);

    input?.addEventListener("input", (event) => {
      applyFilter(event.currentTarget.value);
    });
  </script>
</Layout>
