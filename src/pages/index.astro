---
import Card from "../components/Card.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Astro Starter">
  <main class="hero">
    <div class="hero__content">
      <p class="eyebrow">Template Site</p>
      <h1>Welcome to <span>Astro</span></h1>
      <p class="intro">
        This project has been reset to a minimal starter so you can build from a clean Astro baseline.
      </p>

      <ul class="link-card-grid">
        <Card
          href="https://docs.astro.build"
          title="Documentation"
          body="Learn how Astro works and explore the core concepts."
        />
        <Card
          href="https://astro.build/integrations/"
          title="Integrations"
          body="Add tools and services for styling, content, and deployment."
        />
        <Card
          href="https://astro.build/themes/"
          title="Themes"
          body="Browse starter designs and examples you can use as a base."
        />
        <Card
          href="https://astro.build/chat/"
          title="Community"
          body="Get help, ask questions, and see what other Astro users are building."
        />
      </ul>
    </div>
  </main>
</Layout>
