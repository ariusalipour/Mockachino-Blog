---
import { formatCategoryLabel, formatTopicLabel, type WikiEntry } from "../data/wiki";

interface Props {
  entries: WikiEntry[];
  mode?: "default" | "recent" | "popular";
  limit?: number;
}

const { entries, mode = "default", limit = entries.length } = Astro.props;

function relativeTime(dateValue: string) {
  const delta = Date.now() - Date.parse(dateValue);
  const hours = Math.max(1, Math.floor(delta / 3_600_000));

  if (hours < 24) return `${hours}h ago`;

  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d ago`;

  const months = Math.floor(days / 30);
  return `${months}mo ago`;
}
---

<ol class:list={["entry-list", `entry-list--${mode}`]}>
  {
    entries.slice(0, limit).map((entry, index) => (
      <li class="entry-list__item">
        <a href={`/wiki/${entry.slug}/`} class="entry-list__link">
          <div class="entry-list__header">
            <span class="entry-list__title">{entry.title}</span>
            {mode === "popular" && <span class="entry-list__rank">#{index + 1}</span>}
          </div>
          <p class="entry-list__summary">{entry.summary}</p>
          <div class="entry-list__meta">
            <span>{formatTopicLabel(entry.topic)}</span>
            <span>{formatCategoryLabel(entry.topic, entry.category)}</span>
            {mode === "recent" && <span>{relativeTime(entry.updatedAt)}</span>}
          </div>
        </a>
      </li>
    ))
  }
</ol>
