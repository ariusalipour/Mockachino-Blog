---
interface Props {
  name: string;
  label?: string;
  class?: string;
}

const { name, label = name, class: className } = Astro.props;
---

{name === "home" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 10.5 12 4l8 6.5" /><path d="M6.5 9.5V20h11V9.5" /><path d="M10 20v-5h4v5" /></svg>}
{name === "grid" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="6" height="6" /><rect x="14" y="4" width="6" height="6" /><rect x="4" y="14" width="6" height="6" /><rect x="14" y="14" width="6" height="6" /></svg>}
{name === "pulse" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12h4l2-4 4 8 2-4h6" /></svg>}
{name === "shuffle" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 4h4v4" /><path d="M20 4 5 19" /><path d="M4 5h5l4 4" /><path d="M15 15l5 4v-4h-4" /></svg>}
{name === "book" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 5h11a2 2 0 0 1 2 2v12H8a2 2 0 0 0-2 2Z" /><path d="M6 5a2 2 0 0 0-2 2v12h2" /><path d="M8 9h8" /><path d="M8 13h6" /></svg>}
{name === "tag" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m11 4 9 9-7 7-9-9V4Z" /><circle cx="8" cy="8" r="1" fill="currentColor" stroke="none" /></svg>}
{name === "target" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="7.5" /><circle cx="12" cy="12" r="3.5" /><path d="M12 2v4M22 12h-4M12 22v-4M2 12h4" /></svg>}
{name === "controller" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 8h7a4.5 4.5 0 0 1 4.4 5.4l-.7 3A2 2 0 0 1 16 17.8l-2.8-1.6h-2.4L8 17.8a2 2 0 0 1-3.2-1.4l-.7-3A4.5 4.5 0 0 1 8.5 8Z" /><path d="M8 11v4M6 13h4" /><circle cx="15.5" cy="12" r=".8" fill="currentColor" stroke="none" /><circle cx="17.8" cy="14.2" r=".8" fill="currentColor" stroke="none" /></svg>}
{name === "chip" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="7" y="7" width="10" height="10" /><path d="M9.5 2v3M14.5 2v3M9.5 19v3M14.5 19v3M2 9.5h3M2 14.5h3M19 9.5h3M19 14.5h3" /></svg>}
{name === "sun" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4" /><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9 17 7M7 17l-2.1 2.1" /></svg>}
{name === "moon" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 14.5A8.5 8.5 0 0 1 9.5 4 8.5 8.5 0 1 0 20 14.5Z" /></svg>}
{name === "arrow" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h13" /><path d="m13 6 6 6-6 6" /></svg>}
{name === "clock" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="8" /><path d="M12 7v5l3 2" /></svg>}
{name === "hash" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 4 6 20M18 4l-2 16M4 9h16M3 15h16" /></svg>}
{name === "search" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="6" /><path d="m20 20-4.2-4.2" /></svg>}
{name === "snippet" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m8 8-4 4 4 4M16 8l4 4-4 4M13.5 5 10.5 19" /></svg>}
