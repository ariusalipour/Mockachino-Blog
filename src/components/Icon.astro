---
interface Props {
  name: string;
  label?: string;
  class?: string;
}

const { name, label = name, class: className } = Astro.props;
---

{name === "home" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4.5 10.2 12 4.5l7.5 5.7" /><path d="M6.8 9.5V19h10.4V9.5" /><path d="M10 19v-4.6h4V19" /></svg>}
{name === "grid" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="5" y="5" width="5.2" height="5.2" /><rect x="13.8" y="5" width="5.2" height="5.2" /><rect x="5" y="13.8" width="5.2" height="5.2" /><rect x="13.8" y="13.8" width="5.2" height="5.2" /></svg>}
{name === "pulse" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="7.8" /><path d="M12 7v5l3.3 2.1" /></svg>}
{name === "shuffle" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 7h3.8l3 3.4" /><path d="m14.8 6 4.2 1.2-1.2 4.2" /><path d="M4 17h3.8l8.6-9.2" /><path d="m14.8 18 4.2-1.2-1.2-4.2" /></svg>}
{name === "book" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="5" y="4.8" width="14" height="14.4" rx="1.4" /><path d="M8 8.5h8M8 12h8M8 15.5h5.2" /></svg>}
{name === "tag" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M7 4.8h9.5l2.5 2.5v9.5L16.5 19H7l-2-2V6.8l2-2Z" /><path d="M8.4 8.1h7.2M8.4 11.6h7.2M8.4 15.1h5.6" /></svg>}
{name === "target" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="7.2" /><circle cx="12" cy="12" r="3.3" /><path d="M12 2.5v3.3M21.5 12h-3.3M12 21.5v-3.3M2.5 12h3.3" /></svg>}
{name === "controller" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M8.5 8.2h7a4.6 4.6 0 0 1 4.4 5.6l-.6 2.4a1.9 1.9 0 0 1-2.9 1.2L13.5 16h-3l-2.9 1.4a1.9 1.9 0 0 1-2.9-1.2l-.6-2.4a4.6 4.6 0 0 1 4.4-5.6Z" /><path d="M7 12.3h4M9 10.3v4" /><circle cx="15.8" cy="11.3" r=".75" fill="currentColor" stroke="none" /><circle cx="17.7" cy="13.2" r=".75" fill="currentColor" stroke="none" /></svg>}
{name === "chip" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="m8 6.2 2.3 2.3L8 10.8M16 6.2l-2.3 2.3 2.3 2.3M12.7 5l-1.4 14" /><path d="M5 4.8v14.4h14V4.8Z" opacity=".18" /></svg>}
{name === "sun" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="4" /><path d="M12 2.7v2.7M12 18.6v2.7M2.7 12h2.7M18.6 12h2.7M5.5 5.5l1.9 1.9M16.6 16.6l1.9 1.9M18.5 5.5l-1.9 1.9M7.4 16.6l-1.9 1.9" /></svg>}
{name === "moon" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M18.8 13.9A7.7 7.7 0 0 1 10 4.7a7.8 7.8 0 1 0 8.8 9.2Z" /></svg>}
{name === "arrow" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4.5 12h13" /><path d="m13 6.8 5.5 5.2-5.5 5.2" /></svg>}
{name === "clock" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="7.7" /><path d="M12 7.5v4.9l3.1 1.8" /></svg>}
{name === "hash" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M8 4 6.3 20M17.7 4 16 20M4 9h16M3 15h16" /></svg>}
{name === "search" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="10.5" cy="10.5" r="5.7" /><path d="m15 15 4.2 4.2" /></svg>}
{name === "snippet" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="m8.5 7.2-4 4.8 4 4.8M15.5 7.2l4 4.8-4 4.8" /><path d="M13.5 5.2 10.5 18.8" /></svg>}
{name === "help" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="7.8" /><circle cx="12" cy="12" r="3.2" /><path d="M12 4.4v2M19.6 12h-2M12 19.6v-2M4.4 12h2" /></svg>}
{name === "user" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="8.2" r="3.1" /><path d="M6.2 18.4c1.5-2.4 3.7-3.6 5.8-3.6 2 0 4.3 1.2 5.8 3.6" /><circle cx="12" cy="12" r="8" /></svg>}
{name === "chevron" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="m9 6 6 6-6 6" /></svg>}
{name === "status" && <svg class={className} viewBox="0 0 24 24" aria-label={label} role="img" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3.5 15.5h4l1.7-5.2 2.7 8 2.1-4.4H20.5" /><path d="M3.5 19.5h17" opacity=".55" /></svg>}
